<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Colby's Coffee | Brews & Bites</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/jpeg" href="logo.jpeg">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'DM Serif Display', serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-[#F5F1ED] text-[#2D1B14] scroll-smooth">

    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-stone-200">
        <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <img src="logo.jpeg" alt="Colby's Coffee Logo" class="h-12 w-12 rounded-full object-cover border border-stone-200">
                <div class="text-2xl font-serif font-bold tracking-tight">
                    Colby’s <span class="text-[#D4A373]">Coffee</span>
                </div>
            </div>
            
            <div class="hidden md:flex gap-8 font-medium text-sm uppercase tracking-wider">
                <a href="#menu" class="hover:text-[#D4A373] transition">Menu</a>
                <a href="#" class="hover:text-[#D4A373] transition">Our Story</a>
            </div>

            <button class="relative p-2" onclick="toggleCart()">
                <span class="text-2xl">🛒</span>
                <span id="cart-count" class="absolute top-0 right-0 bg-[#4B2C20] text-white text-[10px] rounded-full h-5 w-5 flex items-center justify-center font-bold">0</span>
            </button>
        </nav>
    </header>

    <section class="py-24 px-6 text-center bg-[#EDE7E0] border-b border-stone-200">
        <div class="max-w-3xl mx-auto">
            <img src="logo.jpeg" alt="Featured Logo" class="h-32 w-32 mx-auto mb-8 rounded-full shadow-xl border-4 border-white">
            <h1 class="text-5xl md:text-6xl font-serif font-bold mb-6">Elevate Your Morning.</h1>
            <p class="text-xl text-stone-600 mb-10 leading-relaxed">
                Colby’s Coffee offers a warm, artisanal escape featuring locally roasted brews and handcrafted sandwiches made with fresh, premium ingredients.
            </p>
            <a href="#menu" class="bg-[#4B2C20] text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-[#5E3A2D] transition-all hover:scale-105 shadow-md inline-block">
                Order Now
            </a>
        </div>
    </section>

    <div class="sticky top-20 bg-[#F5F1ED]/95 backdrop-blur-sm py-6 border-b border-stone-200 z-40">
        <div class="max-w-7xl mx-auto px-6 flex gap-4 overflow-x-auto no-scrollbar">
            <button onclick="filterMenu('all')" class="cat-btn px-6 py-2 rounded-full bg-[#4B2C20] text-white font-bold transition">All</button>
            <button onclick="filterMenu('breakfast')" class="cat-btn px-6 py-2 rounded-full bg-white border border-stone-300 hover:border-[#4B2C20]">Breakfast</button>
            <button onclick="filterMenu('sandwiches')" class="cat-btn px-6 py-2 rounded-full bg-white border border-stone-300 hover:border-[#4B2C20]">Sandwiches</button>
            <button onclick="filterMenu('drinks')" class="cat-btn px-6 py-2 rounded-full bg-white border border-stone-300 hover:border-[#4B2C20]">Drinks</button>
        </div>
    </div>

    <main id="menu" class="max-w-7xl mx-auto px-6 py-16">
        <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
            </div>
    </main>

    <footer class="bg-[#2D1B14] text-[#F5F1ED] py-16 px-6">
        <div class="max-w-7xl mx-auto text-center">
            <div class="flex justify-center items-center gap-3 mb-6">
                <img src="logo.jpeg" class="h-10 w-10 rounded-full grayscale brightness-150">
                <span class="font-serif text-2xl font-bold">Colby's Coffee</span>
            </div>
            <p class="text-stone-400 max-w-md mx-auto mb-8">The perfect neighborhood destination for an elevated morning routine or a cozy afternoon break.</p>
            <p class="text-xs text-stone-500 uppercase tracking-widest">Est. 2024 • Hackensack, NJ</p>
        </div>
    </footer>

    <div id="cart-sidebar" class="fixed inset-0 z-[60] hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="toggleCart()"></div>
        <div class="absolute right-0 top-0 h-full w-full max-w-sm bg-white shadow-2xl p-8 flex flex-col">
            <div class="flex justify-between items-center mb-8">
                <h2 class="text-2xl font-serif font-bold">Your Order</h2>
                <button onclick="toggleCart()" class="text-3xl hover:text-stone-400">&times;</button>
            </div>
            <div id="cart-items" class="flex-grow space-y-4 overflow-y-auto pr-2"></div>
            <div class="border-t border-stone-100 pt-6 mt-6">
                <div class="flex justify-between font-bold text-xl mb-8">
                    <span>Total</span> <span id="cart-total">$0.00</span>
                </div>
                <button class="w-full bg-[#D4A373] text-[#2D1B14] py-4 rounded-xl font-bold text-lg hover:bg-[#C29262] transition shadow-lg">
                    Proceed to Checkout
                </button>
            </div>
        </div>
    </div>

    <script>
        const products = [
            { id: 1, name: "Signature Latte", price: 5.50, category: "drinks", desc: "Double espresso with silky steamed milk and vanilla.", img: "https://images.unsplash.com/photo-1541167760496-162955ed8a9f?auto=format&fit=crop&w=600" },
            { id: 2, name: "Bacon & Egg Brioche", price: 9.00, category: "breakfast", desc: "Farm-fresh egg, crispy bacon, and sharp cheddar.", img: "https://images.unsplash.com/photo-1525351484163-7529414344d8?auto=format&fit=crop&w=600" },
            { id: 3, name: "Pesto Chicken Panini", price: 12.50, category: "sandwiches", desc: "Grilled chicken, fresh pesto, and melted mozzarella.", img: "https://images.unsplash.com/photo-1528735602780-2552fd46c7af?auto=format&fit=crop&w=600" },
            { id: 4, name: "Iced Matcha Tea", price: 6.25, category: "drinks", desc: "Premium ceremonial grade matcha whisked over ice.", img: "https://images.unsplash.com/photo-1515823662972-da630ff7a100?auto=format&fit=crop&w=600" },
            { id: 5, name: "Avocado Sourdough", price: 10.50, category: "breakfast", desc: "Toasted sourdough with radish and chili flakes.", img: "https://images.unsplash.com/photo-1525351484163-7529414344d8?auto=format&fit=crop&w=600" },
            { id: 6, name: "Cold Brew", price: 4.75, category: "drinks", desc: "12-hour slow-steeped coffee, smooth and bold.", img: "https://images.unsplash.com/photo-1517701604599-bb29b565090c?auto=format&fit=crop&w=600" }
        ];

        let cart = [];

        function renderProducts(filter = 'all') {
            const grid = document.getElementById('product-grid');
            grid.innerHTML = products.filter(p => filter === 'all' || p.category === filter).map(p => `
                <div class="bg-white rounded-3xl overflow-hidden border border-stone-100 shadow-sm hover:shadow-xl transition-all duration-300 group">
                    <div class="h-60 overflow-hidden">
                        <img src="${p.img}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    </div>
                    <div class="p-8">
                        <div class="flex justify-between items-start font-bold font-serif text-xl mb-2">
                            <h3>${p.name}</h3> <span class="text-[#4B2C20]">$${p.price.toFixed(2)}</span>
                        </div>
                        <p class="text-sm text-stone-500 mb-8 leading-relaxed">${p.desc}</p>
                        <button onclick="addToCart(${p.id})" class="w-full bg-[#F5F1ED] text-[#4B2C20] py-3 rounded-xl font-bold hover:bg-[#4B2C20] hover:text-white transition-colors">
                            Add to Order
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function addToCart(id) {
            const product = products.find(p => p.id === id);
            cart.push(product);
            updateCart();
        }

        function updateCart() {
            document.getElementById('cart-count').innerText = cart.length;
            const cartItems = document.getElementById('cart-items');
            const totalDisplay = document.getElementById('cart-total');
            
            if (cart.length === 0) {
                cartItems.innerHTML = '<p class="text-stone-400 italic text-center mt-10">Your cart is empty.</p>';
                totalDisplay.innerText = '$0.00';
                return;
            }

            cartItems.innerHTML = cart.map((item, index) => `
                <div class="flex justify-between items-center bg-stone-50 p-4 rounded-2xl border border-stone-100">
                    <div>
                        <p class="font-bold text-sm">${item.name}</p>
                        <p class="text-xs text-stone-500 font-medium">$${item.price.toFixed(2)}</p>
                    </div>
                    <button onclick="removeFromCart(${index})" class="text-stone-300 hover:text-red-400 transition">✕</button>
                </div>
            `).join('');

            const total = cart.reduce((sum, item) => sum + item.price, 0);
            totalDisplay.innerText = `$${total.toFixed(2)}`;
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            updateCart();
        }

        function filterMenu(cat) {
            renderProducts(cat);
            document.querySelectorAll('.cat-btn').forEach(btn => {
                btn.classList.remove('bg-[#4B2C20]', 'text-white');
                btn.classList.add('bg-white', 'text-stone-600');
            });
            event.target.classList.add('bg-[#4B2C20]', 'text-white');
        }

        function toggleCart() {
            document.getElementById('cart-sidebar').classList.toggle('hidden');
        }

        // Initial Load
        renderProducts();
        updateCart();
    </script>
</body>
</html>
 
